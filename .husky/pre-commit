#!/usr/bin/env sh
set -eu

# Fast pre-commit checks for local commit safety.
# Full verification remains enforced in CI.

printf '%s\n' "🔍 Running pre-commit fast checks..."

# Phase 1: Staged formatting/linting
printf '\n📋 Phase 1: Staged Formatting & Linting\n'
npx lint-staged

# Phase 2: Fast static analysis
printf '\n📋 Phase 2: TypeScript Check\n'
npm run type-check

printf '\n✅ Pre-commit fast checks passed!\n'
printf '%s\n' "   Full verification remains in CI."
printf '%s\n' "   Run manually when needed:"
printf '%s\n' "   - npm run deadcode:check"
printf '%s\n' "   - npm run dup:all"
printf '%s\n' "   - npm run test:safeall"
