{
  "name": "zap-pilot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env VITE_ENABLE_RQ_DEVTOOLS=0 VITE_ENABLE_LOG_VIEWER=0 vite",
    "dev:log": "cross-env VITE_ENABLE_RQ_DEVTOOLS=0 VITE_ENABLE_LOG_VIEWER=1 vite",
    "build": "vite build",
    "start": "vite preview --host 0.0.0.0 --port 4173",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "echo '🔍 Running TypeScript type-check...' && tsc --noEmit && echo '✅ Type-check completed successfully!'",
    "test": "cross-env NODE_OPTIONS=--max-old-space-size=1024 vitest run",
    "test:unit": "cross-env NODE_OPTIONS=--max-old-space-size=1024 vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest --watch",
    "test:safe": "cross-env NODE_OPTIONS=--max-old-space-size=1024 vitest run --reporter=verbose",
    "test:safeall": "cross-env NODE_OPTIONS=--max-old-space-size=1024 pnpm run test:coverage && pnpm run test:safe:e2e",
    "test:safe:e2e": "cross-env NODE_OPTIONS=--max-old-space-size=1024 PLAYWRIGHT_PORT=3099 node scripts/run-e2e-safe.js",
    "test:coverage": "cross-env NODE_OPTIONS=--max-old-space-size=1024 node scripts/run-sharded-coverage.js && node scripts/check-coverage.js",
    "test:e2e": "cross-env PLAYWRIGHT_PORT=3099 playwright test",
    "test:e2e:ui": "cross-env PLAYWRIGHT_PORT=3099 playwright test --ui",
    "test:e2e:headed": "cross-env PLAYWRIGHT_PORT=3099 playwright test --headed",
    "test:e2e:debug": "cross-env PLAYWRIGHT_PORT=3099 playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:all": "pnpm run test:coverage && pnpm run test:e2e",
    "deadcode": "node scripts/run-deadcode.js default",
    "deadcode:ci": "node scripts/run-deadcode.js ci",
    "deadcode:fix": "node scripts/run-deadcode.js fix",
    "deadcode:check": "node scripts/run-deadcode.js check",
    "deadcode:exports": "ts-prune -p tsconfig.tsprune.json",
    "dup:check": "node scripts/run-dup-check.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@davidtnfsh/etl-contracts": "^1.0.0",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.85.3",
    "@tanstack/react-query-devtools": "^5.85.3",
    "dayjs": "^1.11.19",
    "framer-motion": "^12.19.1",
    "lucide-react": "^0.523.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.68.0",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.6.0",
    "viem": "^2.47.12",
    "vite-plugin-pwa": "^1.2.0",
    "wagmi": "^3.6.1",
    "workbox-build": "^7.4.0",
    "workbox-window": "^7.4.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "baseline-browser-mapping": "^2.9.13",
    "cross-env": "^10.0.0",
    "eslint": "^9",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-secrets": "^2.2.1",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-unicorn": "^62.0.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.5",
    "jsdom": "^25.0.1",
    "knip": "^5.68.0",
    "lint-staged": "^16.1.2",
    "pino-pretty": "^13.1.1",
    "postcss": "^8.4.47",
    "prettier": "^3.6.1",
    "tailwindcss": "^4",
    "ts-prune": "^0.10.3",
    "typescript": "^5",
    "typescript-eslint": "^8.46.2",
    "vite": "^7.1.12",
    "vitest": "^4.1.4"
  },
  "overrides": {},
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "npx prettier --write",
      "npx eslint --fix --max-warnings 0"
    ],
    "*.{json,md,yml,yaml}": [
      "npx prettier --write"
    ]
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
