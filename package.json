{
  "name": "zap-pilot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=3072 next dev",
    "dev:turbo": "cross-env NODE_OPTIONS=--max-old-space-size=3072 next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "echo '🔍 Running TypeScript type-check...' && tsc --noEmit && echo '✅ Type-check completed successfully!'",
    "test": "cross-env NODE_OPTIONS=--max-old-space-size=1536 vitest run",
    "test:unit": "cross-env NODE_OPTIONS=--max-old-space-size=1536 vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest --watch",
    "test:safe": "cross-env NODE_OPTIONS=--max-old-space-size=1536 vitest run --reporter=verbose",
    "test:safeall": "cross-env NODE_OPTIONS=--max-old-space-size=1536 pnpm run test:coverage && pnpm run test:safe:e2e",
    "test:safe:e2e": "cross-env NODE_OPTIONS=--max-old-space-size=2048 PLAYWRIGHT_PORT=3099 node scripts/run-e2e-safe.js",
    "test:coverage": "cross-env NODE_OPTIONS=--max-old-space-size=6144 node scripts/run-sharded-coverage.js && node scripts/check-coverage.js",
    "test:e2e": "cross-env PLAYWRIGHT_PORT=3099 playwright test",
    "test:e2e:ui": "cross-env PLAYWRIGHT_PORT=3099 playwright test --ui",
    "test:e2e:headed": "cross-env PLAYWRIGHT_PORT=3099 playwright test --headed",
    "test:e2e:debug": "cross-env PLAYWRIGHT_PORT=3099 playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:all": "pnpm run test:coverage && pnpm run test:e2e",
    "deadcode": "node scripts/run-deadcode.js default",
    "deadcode:ci": "node scripts/run-deadcode.js ci",
    "deadcode:fix": "node scripts/run-deadcode.js fix",
    "deadcode:check": "node scripts/run-deadcode.js check",
    "deadcode:exports": "ts-prune -p tsconfig.tsprune.json",
    "dup:check": "node scripts/run-dup-check.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@davidtnfsh/etl-contracts": "^1.0.0",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.85.3",
    "@tanstack/react-query-devtools": "^5.85.3",
    "dayjs": "^1.11.19",
    "framer-motion": "^12.19.1",
    "lucide-react": "^0.523.0",
    "next": "^16.0.7",
    "next-pwa": "^5.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.68.0",
    "recharts": "^3.6.0",
    "thirdweb": "^5.105.10",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "baseline-browser-mapping": "^2.9.13",
    "cross-env": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.3.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-secrets": "^2.2.1",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-unicorn": "^62.0.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.5",
    "jsdom": "^25.0.1",
    "knip": "^5.68.0",
    "lint-staged": "^16.1.2",
    "pino-pretty": "^13.1.1",
    "postcss": "^8.4.47",
    "prettier": "^3.6.1",
    "tailwindcss": "^4",
    "ts-prune": "^0.10.3",
    "typescript": "^5",
    "typescript-eslint": "^8.46.2",
    "vite": "^7.1.12",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "@walletconnect/sign-client": "2.22.4",
    "@walletconnect/universal-provider": "2.22.4",
    "@walletconnect/core": "2.22.4",
    "@walletconnect/types": "2.22.4",
    "@walletconnect/utils": "2.22.4",
    "@walletconnect/logger": "3.0.0"
  },
  "pnpm": {
    "overrides": {
      "minimatch@3>brace-expansion": "^1.1.11",
      "minimatch@>=10.0.0 <10.2.1": ">=10.2.1",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
      "serialize-javascript@<=7.0.2": ">=7.0.3",
      "serialize-javascript@<7.0.5": ">=7.0.5",
      "lodash@<=4.17.23": ">=4.18.0",
      "defu@<=6.1.4": ">=6.1.5",
      "vite@>=7.0.0 <=7.3.1": ">=7.3.2",
      "vite@>=7.1.0 <=7.3.1": ">=7.3.2",
      "hono@<4.12.12": ">=4.12.12",
      "hono@>=4.0.0 <=4.12.11": ">=4.12.12"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "npx prettier --write",
      "npx eslint --fix --max-warnings 0"
    ],
    "*.{json,md,yml,yaml}": [
      "npx prettier --write"
    ]
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
