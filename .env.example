# API Configuration
NEXT_PUBLIC_INTENT_ENGINE_URL=http://127.0.0.1:3002
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001
NEXT_PUBLIC_ACCOUNT_API_URL=http://127.0.0.1:3004
NEXT_PUBLIC_ANALYTICS_ENGINE_URL=http://localhost:8001

# React Query Devtools: set to 1 only when debugging (uses extra browser memory)
NEXT_PUBLIC_ENABLE_RQ_DEVTOOLS=0

# In-app log viewer (dev): set to 1 to show the floating log panel; keep 0 to save RAM
NEXT_PUBLIC_ENABLE_LOG_VIEWER=0

# Logging Configuration
# Enable debug logging in production (default: false)
NEXT_PUBLIC_ENABLE_DEBUG_LOGGING=false
# Enable development logging (default: true)
NEXT_PUBLIC_ENABLE_DEV_LOGGING=true